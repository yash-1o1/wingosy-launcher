{
  "name": "wingosy-launcher",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.12.1",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test:e2e": "wdio run wdio.conf.js",
    "test:e2e:setup": "wdio run wdio.conf.js --spec e2e-webdriver/setup-wizard.spec.js",
    "test:e2e:app": "wdio run wdio.conf.js --spec e2e-webdriver/app.spec.js",
    "test:e2e:settings": "wdio run wdio.conf.js --spec e2e-webdriver/settings.spec.js",
    "test:e2e:sensing": "wdio run wdio.conf.js --spec e2e-webdriver/emulator-sensing.spec.js",
    "test:e2e:download": "wdio run wdio.conf.js --spec e2e-webdriver/emulator-download.spec.js",
    "test:e2e:cores": "wdio run wdio.conf.js --spec e2e-webdriver/retroarch-cores.spec.js",
    "test:e2e:roms": "wdio run wdio.conf.js --spec e2e-webdriver/rom-download.spec.js",
    "test:e2e:games": "wdio run wdio.conf.js --spec e2e-webdriver/game-launch.spec.js",
    "test:e2e:gba": "wdio run wdio.conf.js --spec e2e-webdriver/game-launch-gba.spec.js",
    "test:e2e:coverage": "wdio run wdio.conf.js --spec e2e-webdriver/coverage-analysis.spec.js",
    "test:rust": "cd src-tauri && cargo test -- --nocapture",
    "test:rust:unit": "cd src-tauri && cargo test --bin wingosy-launcher -- --nocapture",
    "test:rust:critical": "cd src-tauri && cargo test critical -- --nocapture"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.0",
    "@mui/material": "^6.4.0",
    "@tauri-apps/api": "^1.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^1.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "vite": "^5.4.0"
  }
}
