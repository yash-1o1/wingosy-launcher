{
  "name": "wingosy-launcher",
  "private": true,
  "version": "0.0.87",
  "packageManager": "npm@11.12.1",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite",
    "build": "vite build",
    "build:windows": "npm run build && tauri build",
    "lint": "npm run lint:frontend && npm run lint:rust",
    "lint:frontend": "eslint src",
    "lint:rust": "cd src-tauri && cargo clippy --all-targets --all-features -- -D warnings",
    "typecheck": "tsc --project jsconfig.json",
    "icons:extract": "node scripts/extract-console-icons.mjs",
    "icons:windows": "node scripts/generate-windows-icons.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "test:e2e": "wdio run wdio.conf.js",
    "test:e2e:setup": "wdio run wdio.conf.js --spec e2e-webdriver/setup-wizard.spec.js",
    "test:e2e:app": "wdio run wdio.conf.js --spec e2e-webdriver/app.spec.js",
    "test:e2e:settings": "wdio run wdio.conf.js --spec e2e-webdriver/settings.spec.js",
    "test:e2e:sensing": "wdio run wdio.conf.js --spec e2e-webdriver/emulator-sensing.spec.js",
    "test:e2e:download": "wdio run wdio.conf.js --spec e2e-webdriver/emulator-download.spec.js",
    "test:e2e:cores": "wdio run wdio.conf.js --spec e2e-webdriver/retroarch-cores.spec.js",
    "test:e2e:roms": "wdio run wdio.conf.js --spec e2e-webdriver/rom-download.spec.js",
    "test:e2e:games": "wdio run wdio.conf.js --spec e2e-webdriver/game-launch.spec.js",
    "test:e2e:gba": "wdio run wdio.conf.js --spec e2e-webdriver/game-launch-gba.spec.js",
    "test:e2e:coverage": "wdio run wdio.conf.js --spec e2e-webdriver/coverage-analysis.spec.js",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:rust": "node -e \"require('fs').mkdirSync('coverage/rust',{recursive:true})\" && cd src-tauri && cargo llvm-cov --workspace --lcov --output-path ../coverage/rust/lcov.info",
    "test:unit:watch": "vitest",
    "test:rust": "cd src-tauri && cargo test -- --nocapture",
    "test:rust:unit": "cd src-tauri && cargo test --bin wingosy-launcher -- --nocapture",
    "test:rust:critical": "cd src-tauri && cargo test critical -- --nocapture",
    "test:rust:cores": "cd src-tauri && cargo test all_mapped_retroarch_core_buildbot_zips_are_valid -- --ignored --nocapture",
    "test:e2e:immersive": "wdio run wdio.conf.js --spec e2e-webdriver/immersive.spec.js",
    "version:set": "node scripts/set-version.mjs",
    "version:bump": "node scripts/bump-version.mjs"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@iconify/react": "^6.0.2",
    "@mui/icons-material": "^6.4.0",
    "@mui/material": "^6.4.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@iconify-json/simple-icons": "^1.2.77",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.2.7",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "edgedriver": "^6.3.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^29.0.2",
    "png-to-ico": "^3.0.1",
    "png2icons": "^2.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.8.3",
    "vite": "^5.4.0",
    "vitest": "^3.0.5"
  }
}
